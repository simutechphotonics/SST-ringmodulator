#SimuTech Group
#Author: Stephen Lin
#Date: 2026
#The scripts and files included are for educational purpose for SimuTech Group's customers.
#Customers are free to utilize the scripts and files in their own product design flows.

#This script initializes the parameter variables and setups the device in Lumerical LSF.

RingFunctions; #Loads the locally pathed RingFunction.lsf to access the setup function.

#PARAMETERS
#Units: ums
wg_thickness = 0.22; #height of wg
wg_width = 0.5; #width of wg
uppercladding_thickness = 2.0;
lowercladding_thickness = 2.0;
sidewall_angle = 90;
ring_radius = 10; #1.55/2/3.14/3.4784
ring_gap = 0.200;
ring_racetrack_length = 5;
wavelength_start = 1.5;
wavelength_stop = 1.6;

#additional options
slab_thickness = 0; #include if slab, use 0 for strip waveguides

#SIMULATION REGION
sim_width = 2.0e-6; #span amount around wg
sim_height = 1.0e-6; #span amount around wg

#MATERIALS
material_uppercladding = "SiO2 (Glass) - Palik";
material_lowercladding = "SiO2 (Glass) - Palik";
material_wg = "Si (Silicon) - Palik";

### Run Function
setup_RingModulator( 
wg_thickness,
wg_width,
uppercladding_thickness,
lowercladding_thickness,
sidewall_angle, 
ring_radius, 
ring_gap,
ring_racetrack_length,
wavelength_start,
wavelength_stop, 
slab_thickness,
sim_width,
sim_height,
material_uppercladding,
material_lowercladding,
material_wg
);

clear;
clearfunctions;